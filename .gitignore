# KoadOS v3 Exhaustive Ignore Rules

# --- Instance-Specific State & Config ---
plans/
new_world/
config/kernel.toml
config/redis.conf
config/integrations/*.toml
.env
.env.*

# --- Agents Directory (Instance State) ---
agents/bays/*
agents/bodies/*
agents/inbox/*
agents/sessions_archive/*
agents/SESSIONS_LOG.md
agents/.claude/
agents/.gemini/

# Crews: Ignore all manifests except the distribution template
agents/crews/*
!agents/crews/TEMPLATE.md

# KAPVs: Ignore all personal vaults (Identities, Memory, local tasks)
agents/KAPVs/*

# Quests: Ignore instance-specific quests
agents/quests/master_development/
# (stable_release and side_quests remain tracked as distribution roadmaps)

# Root-level ignored data
cache/
logs/
portals/
run/
data/db/
data/redis/
backups/
*.db
*.db-shm
*.db-wal
*.log
*.log.*
*.rdb

# --- Binaries & Build Artifacts ---
bin/
!bin/*.sh
target/
**/target/
node_modules/
**/node_modules/
debug/
release/
.crates.toml
.crates2.json

# --- Standard Ignore Rules ---
AGENTS.md
CLAUDE.md
GEMINI.md

# Claude Code Agent Workspace (Root only)
/.claude/
agents/.claude/worktrees/
**/.claude/worktrees/

# IDE & OS
.vscode/
.DS_Store
.idea/
.codex/
*.swp
*.swo