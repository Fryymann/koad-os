# --- Binaries ---
bin/
!bin/*.sh

# --- Claude Code Agent Workspace ---
# Worktrees are git-managed checkouts and must never be committed into the repo.
# settings.local.json is a machine-local Claude Code config file.
# Agent working-memory files (context.md, log.md, README.md) are ephemeral
# per-session artefacts, not project source.
# Rules scoped to /.claude/ (root only) so agents/.claude/ memory is tracked.
/.claude/
/.claude/worktrees/
/.claude/settings.local.json
/.claude/README.md
/.claude/context.md
/.claude/log.md
/.claude/*.json
/.claude/*.md
# Worktree checkouts inside agent bays are git-managed, never committed.
agents/.claude/worktrees/

# --- Personal Agent Bays & Admiral Commands ---
.admiral/
.helm/
.tyr/

# -- Portal Symlinks ---

/portals/*