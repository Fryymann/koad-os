# KoadOS v3 Exhaustive Ignore Rules

# --- Instance-Specific State & Config ---
config/kernel.toml
config/redis.conf
.env
.env.*
agents/crews/*.md
!agents/crews/TEMPLATE.md
agents/SESSIONS_LOG.md
agents/sessions_archive/
agents/bays/
bays/
cache/
logs/
run/
data/db/
data/redis/
backups/
agents/KAPVs/*/memory/
*.db
*.db-shm
*.db-wal
*.log
*.log.*
*.rdb

# --- Binaries & Build Artifacts ---
bin/
!bin/*.sh
target/
**/target/
node_modules/
**/node_modules/
debug/
release/
.crates.toml
.crates2.json

# --- Standard Ignore Rules ---
# Claude Code Agent Workspace (Root only)
/.claude/
agents/.claude/worktrees/
**/.claude/worktrees/

# IDE & OS
.vscode/
.DS_Store
.idea/
.codex/
*.swp
*.swo