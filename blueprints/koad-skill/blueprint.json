{
  "id": "koad-skill",
  "name": "KoadOS Skill (Python)",
  "description": "Scaffold a new automated skill for KoadOS",
  "variables": {
    "skill_name": "Name of the skill (e.g. security_scanner)",
    "category": "Skill category (e.g. global, project, admin)"
  },
  "steps": [
    { "type": "mkdir", "path": "skills/{{category}}" },
    { "type": "render", "src": "skill.py.j2", "dest": "skills/{{category}}/{{skill_name}}.py" },
    { "type": "run_shell", "cmd": "chmod +x skills/{{category}}/{{skill_name}}.py" }
  ]
}
