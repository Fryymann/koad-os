{
    "name": "{{ name }}-backend",
    "version": "1.0.0",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "functions-framework --target={{ handler_name }}",
        "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathIgnorePatterns=integration.test.js",
        "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration.test.js",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
    },
    "dependencies": {
        "@google-cloud/functions-framework": "^3.5.0",
        "airtable": "^0.12.2",
        "dotenv": "^17.2.3",
        "stripe": "^20.2.0",
        "validator": "^13.11.0"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "jest": "^29.7.0",
        "supertest": "^6.3.3"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "transform": {}
    }
}
