import functions from '@google-cloud/functions-framework';
import { logger } from './logger.js';
import { config } from './config.js';

/**
 * Cloud Function to handle {{ title }}
 */
export const {{ handler_name }} = async (req, res) => {
  // Standard CORS headers
  res.set('Access-Control-Allow-Origin', '*');

  if (req.method === 'OPTIONS') {
    res.set('Access-Control-Allow-Methods', 'POST');
    res.set('Access-Control-Allow-Headers', 'Content-Type');
    res.set('Access-Control-Max-Age', '3600');
    res.status(204).send('');
    return;
  }

  logger.info('{{ handler_name }} triggered', { method: req.method, path: req.path });

  try {
    res.status(200).json({
        message: '{{ title }} API Ready',
        mode: config.stripeMode
    });
  } catch (error) {
    logger.error('Error in {{ handler_name }}', { error: error.message, stack: error.stack });
    res.status(500).json({ error: 'Internal Server Error' });
  }
};

functions.http('{{ handler_name }}', {{ handler_name }});
